<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="payment_clover.PaymentTerminal">
        <div class="o_action container-fluid py-4">
            <div class="row justify-content-center">
                <div class="col-lg-6 col-md-8">

                    <h2 class="mb-4">
                        <i class="fa fa-credit-card me-2"/>
                        Clover Payment Terminal
                    </h2>

                    <!-- ========== FORM STEP ========== -->
                    <div t-if="state.step === 'form'" class="card shadow-sm">
                        <div class="card-body">

                            <!-- Provider selector (if multiple) -->
                            <div t-if="state.providers.length > 1" class="mb-3">
                                <label class="form-label fw-bold">Payment Provider</label>
                                <select class="form-select"
                                        t-on-change="(ev) => this.state.selectedProviderId = parseInt(ev.target.value)">
                                    <option value="">-- Select --</option>
                                    <t t-foreach="state.providers" t-as="prov" t-key="prov.id">
                                        <option t-att-value="prov.id"
                                                t-att-selected="prov.id === state.selectedProviderId">
                                            <t t-esc="prov.name"/>
                                            <t t-if="prov.state === 'test'"> (TEST)</t>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div t-elif="state.providers.length === 1" class="mb-3">
                                <span class="badge bg-primary">
                                    <t t-esc="state.providers[0].name"/>
                                    <t t-if="state.providers[0].state === 'test'"> (TEST)</t>
                                </span>
                            </div>
                            <div t-elif="state.providers.length === 0" class="alert alert-warning">
                                No Clover payment provider is configured.
                                Please set one up under Payment Providers.
                            </div>

                            <!-- Customer search -->
                            <div class="mb-3">
                                <label class="form-label fw-bold">Customer</label>
                                <input type="text" class="form-control"
                                       placeholder="Search by name, email, or phone..."
                                       t-model="state.partnerSearch"
                                       t-on-input="onSearchPartner"/>
                                <div t-if="state.partners.length > 0"
                                     class="list-group mt-1 position-absolute shadow"
                                     style="z-index: 1000; max-height: 200px; overflow-y: auto;">
                                    <t t-foreach="state.partners" t-as="p" t-key="p.id">
                                        <button type="button"
                                                class="list-group-item list-group-item-action"
                                                t-on-click="() => this.selectPartner(p.id)">
                                            <strong t-esc="p.name"/>
                                            <small t-if="p.email" class="text-muted ms-2"
                                                   t-esc="p.email"/>
                                        </button>
                                    </t>
                                </div>
                            </div>

                            <!-- Amount + Currency -->
                            <div class="row mb-3">
                                <div class="col-8">
                                    <label class="form-label fw-bold">Amount</label>
                                    <input type="number" class="form-control"
                                           step="0.01" min="0.01"
                                           placeholder="0.00"
                                           t-model="state.amount"/>
                                </div>
                                <div class="col-4">
                                    <label class="form-label fw-bold">Currency</label>
                                    <select class="form-select"
                                            t-on-change="(ev) => this.state.selectedCurrencyId = parseInt(ev.target.value)">
                                        <t t-foreach="state.currencies" t-as="cur" t-key="cur.id">
                                            <option t-att-value="cur.id"
                                                    t-att-selected="cur.id === state.selectedCurrencyId">
                                                <t t-esc="cur.name"/> (<t t-esc="cur.symbol"/>)
                                            </option>
                                        </t>
                                    </select>
                                </div>
                            </div>

                            <!-- Description -->
                            <div class="mb-3">
                                <label class="form-label fw-bold">Description (optional)</label>
                                <input type="text" class="form-control"
                                       placeholder="e.g. Annual dues, Event ticket..."
                                       t-model="state.description"/>
                            </div>

                            <!-- Card input (Clover iframe) -->
                            <div class="mb-3 p-3 border rounded bg-light">
                                <h6 class="fw-bold mb-3">
                                    <i class="fa fa-lock me-1"/>
                                    Card Details
                                    <t t-if="state.cardReady">
                                        <span class="badge bg-success ms-2">
                                            <i class="fa fa-check me-1"/>Ready
                                        </span>
                                    </t>
                                    <t t-elif="state.cardError">
                                        <span class="badge bg-danger ms-2">
                                            <i class="fa fa-exclamation-triangle me-1"/>Error
                                        </span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge bg-secondary ms-2">
                                            <i class="fa fa-spinner fa-spin me-1"/>Loading...
                                        </span>
                                    </t>
                                </h6>
                                <t t-if="state.cardError">
                                    <div class="alert alert-danger small mb-2">
                                        <t t-esc="state.cardError"/>
                                    </div>
                                </t>
                                <div class="mb-2">
                                    <label class="form-label small">Card Number</label>
                                    <div id="terminal-card-number" class="form-control"
                                         style="height: 40px; padding-top: 10px;"></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5">
                                        <label class="form-label small">Exp Date</label>
                                        <div id="terminal-card-date" class="form-control"
                                             style="height: 40px; padding-top: 10px;"></div>
                                    </div>
                                    <div class="col-3">
                                        <label class="form-label small">CVV</label>
                                        <div id="terminal-card-cvv" class="form-control"
                                             style="height: 40px; padding-top: 10px;"></div>
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label small">ZIP</label>
                                        <div id="terminal-card-postal" class="form-control"
                                             style="height: 40px; padding-top: 10px;"></div>
                                    </div>
                                </div>
                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm mt-1"
                                        t-on-click="initCloverIframe">
                                    <i class="fa fa-refresh me-1"/>
                                    Re-initialize Card Reader
                                </button>
                            </div>

                            <!-- Submit -->
                            <button type="button"
                                    class="btn btn-primary btn-lg w-100"
                                    t-att-disabled="!state.cardReady"
                                    t-on-click="processPayment">
                                <i class="fa fa-bolt me-2"/>
                                Process Payment
                            </button>
                        </div>
                    </div>

                    <!-- ========== PROCESSING STEP ========== -->
                    <div t-if="state.step === 'processing'" class="card shadow-sm">
                        <div class="card-body text-center py-5">
                            <div class="spinner-border text-primary mb-3" role="status">
                                <span class="visually-hidden">Processing...</span>
                            </div>
                            <h4>Processing Payment...</h4>
                            <p class="text-muted">Please wait while the transaction completes.</p>
                            <p class="text-muted small">This should take no more than 30 seconds.</p>
                        </div>
                    </div>

                    <!-- ========== RESULT STEP ========== -->
                    <div t-if="state.step === 'result'" class="card shadow-sm">
                        <div class="card-body text-center py-5">
                            <div t-if="state.resultStatus === 'ok'">
                                <i class="fa fa-check-circle text-success"
                                   style="font-size: 4rem;"/>
                                <h3 class="mt-3 text-success">Payment Approved</h3>
                            </div>
                            <div t-else="">
                                <i class="fa fa-times-circle text-danger"
                                   style="font-size: 4rem;"/>
                                <h3 class="mt-3 text-danger">Payment Failed</h3>
                            </div>
                            <p class="mt-2" t-esc="state.resultMessage"/>
                            <p t-if="state.resultReference" class="text-muted small">
                                Reference: <t t-esc="state.resultReference"/>
                            </p>
                            <button type="button"
                                    class="btn btn-primary mt-3"
                                    t-on-click="resetForm">
                                <i class="fa fa-plus me-1"/>
                                New Payment
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </t>

</templates>
