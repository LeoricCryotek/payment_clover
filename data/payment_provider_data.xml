<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Create the Clover payment provider record.
             Defaults to USD / United States since Elks lodges
             operate exclusively in the US. -->
        <record id="payment_provider_clover" model="payment.provider">
            <field name="name">Clover</field>
            <field name="code">clover</field>
            <field name="state">disabled</field>
            <field name="is_published">0</field>
            <field name="module_to_buy">0</field>
            <field name="inline_form_view_id" ref="inline_form"/>
            <field name="available_country_ids"
                   eval="[(6, 0, [ref('base.us')])]"/>
        </record>
    </data>
</odoo>
