<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend the payment provider form to show Clover fields -->
    <record id="payment_provider_form_clover" model="ir.ui.view">
        <field name="name">payment.provider.form.clover</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <div class="alert alert-info mb-3" role="alert"
                     colspan="2"
                     invisible="code != 'clover' or state == 'enabled'">
                    <strong>Tip:</strong> You can save in Disabled or Test
                    mode without credentials. Fill them in, then switch to
                    Enabled when ready.
                </div>
                <group invisible="code != 'clover'" string="Clover API Credentials">
                    <field name="clover_api_key"
                           password="True"
                           placeholder="e.g. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                           required="state == 'enabled' and code == 'clover'"/>
                    <field name="clover_pakms_key"
                           placeholder="Your public tokenizer API key"
                           required="state == 'enabled' and code == 'clover'"/>
                    <field name="clover_merchant_id"
                           placeholder="e.g. ABC123DEF456"
                           required="state == 'enabled' and code == 'clover'"/>
                </group>
            </group>

            <!-- Sync Items button in the header -->
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_sync_clover_items"
                            string="Sync Items from Clover"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"
                            invisible="code != 'clover' or state == 'disabled'"
                            confirm="This will fetch all items from your Clover inventory. Continue?"/>
                </header>
            </xpath>

            <!-- Clover Items notebook page -->
            <xpath expr="//notebook" position="inside">
                <page string="Clover Items"
                      invisible="code != 'clover'"
                      name="clover_items">
                    <field name="clover_item_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="name" readonly="1"/>
                            <field name="clover_item_id" readonly="1"/>
                            <field name="price" readonly="1"/>
                            <field name="price_type" readonly="1"/>
                            <field name="sku" readonly="1"/>
                            <field name="category_name" readonly="1"/>
                            <field name="product_id"/>
                            <field name="active" readonly="1"/>
                            <field name="last_synced" readonly="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Clover Item list view -->
    <record id="clover_item_view_list" model="ir.ui.view">
        <field name="name">clover.item.list</field>
        <field name="model">clover.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="clover_item_id"/>
                <field name="price" string="Price ($)"/>
                <field name="price_type"/>
                <field name="sku"/>
                <field name="category_name"/>
                <field name="provider_id"/>
                <field name="product_id"/>
                <field name="last_synced"/>
            </list>
        </field>
    </record>

    <!-- Clover Item form view -->
    <record id="clover_item_view_form" model="ir.ui.view">
        <field name="name">clover.item.form</field>
        <field name="model">clover.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Clover Details">
                            <field name="name"/>
                            <field name="clover_item_id"/>
                            <field name="provider_id"/>
                            <field name="price"/>
                            <field name="price_type"/>
                            <field name="sku"/>
                            <field name="category_name"/>
                        </group>
                        <group string="Odoo Link">
                            <field name="product_id"/>
                            <field name="active"/>
                            <field name="hidden"/>
                            <field name="last_synced"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Clover Items action -->
    <record id="clover_item_action" model="ir.actions.act_window">
        <field name="name">Clover Items</field>
        <field name="res_model">clover.item</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Clover items synced yet.
            </p>
            <p>
                Go to Payment Providers → Clover and click
                "Sync Items from Clover" to import your inventory.
            </p>
        </field>
    </record>

</odoo>
